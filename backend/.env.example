# Server Port
PORT=5000

# Environment (development, production, testing)
NODE_ENV=development

# Database Connection (PostgreSQL)
# Note: For Docker, host should be "postgres" or "localhost" depending on environment
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/smarterp?schema=public"

# Redis Connection
REDIS_URL="redis://localhost:6379"

# JWT Auth Configuration
JWT_SECRET="smarterp_super_secret_access_token_key_12345"
JWT_REFRESH_SECRET="smarterp_super_secret_refresh_token_key_54321"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Sentry DSN (Optional)
SENTRY_DSN=""

# Stripe Payment Config (Optional for MVP, required for full billing)
STRIPE_SECRET_KEY=""

# Super admin seed (npm run seed:super-admin)
SUPER_ADMIN_EMAIL="superadmin@smarterp.local"
SUPER_ADMIN_PASSWORD="SuperAdmin@123"
