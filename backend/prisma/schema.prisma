datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum Role {
  SUPER_ADMIN
  BUSINESS_OWNER
  MANAGER
  STAFF
  CASHIER
}

model Tenant {
  id               String            @id @default(uuid())
  name             String
  subDomain        String            @unique
  plan             Plan              @default(FREE)
  status           TenantStatus      @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  categories       Category[]
  warehouses       Warehouse[]
  products         Product[]
  suppliers        Supplier[]
  customers        Customer[]
  sales            Sale[]
  saleItems        SaleItem[]
  returns          ReturnTransaction[]
  returnItems      ReturnItem[]
  purchaseOrders   PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  employees        Employee[]
  attendance       Attendance[]
  leaveRequests    LeaveRequest[]
  auditLogs        AuditLog[]
  stockAdjustments StockAdjustment[]
  stockTransfers   StockTransfer[]
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(STAFF)
  firstName    String?
  lastName     String?
  isVerified   Boolean    @default(false)
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee     Employee?
  sales        Sale[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name, tenantId])
}

model Warehouse {
  id             String            @id @default(uuid())
  name           String
  location       String?
  tenantId       String
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stocks         StockAdjustment[]
  transfersFrom  StockTransfer[]   @relation("FromWarehouse")
  transfersTo    StockTransfer[]   @relation("ToWarehouse")
  products       ProductWarehouse[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([name, tenantId])
}

model Product {
  id                String             @id @default(uuid())
  name              String
  sku               String
  barcode           String?
  description       String?
  purchasePrice     Float
  sellingPrice      Float
  quantity          Int                @default(0)
  lowStockThreshold Int                @default(10)
  expiryDate        DateTime?
  status            String             @default("ACTIVE")
  categoryId        String?
  category          Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  supplierId        String?
  supplier          Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  tenantId          String
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleItems         SaleItem[]
  warehouses        ProductWarehouse[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([sku, tenantId])
  @@unique([barcode, tenantId])
}

model ProductWarehouse {
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int       @default(0)

  @@id([productId, warehouseId])
}

model Supplier {
  id             String          @id @default(uuid())
  name           String
  contactName    String?
  email          String?
  phone          String?
  address        String?
  tenantId       String
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products       Product[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Customer {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  email         String?
  address       String?
  loyaltyPoints Int      @default(0)
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales         Sale[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([phone, tenantId])
}

model Sale {
  id            String              @id @default(uuid())
  invoiceNo     String
  totalAmount   Float
  discount      Float               @default(0)
  tax           Float               @default(0)
  grandTotal    Float
  paymentMethod String
  paymentStatus String
  amountPaid    Float
  changeAmount  Float               @default(0)
  customerId    String?
  customer      Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  userId        String
  user          User                @relation(fields: [userId], references: [id])
  tenantId      String
  tenant        Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         SaleItem[]
  returns       ReturnTransaction[]
  isOffline     Boolean             @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@unique([invoiceNo, tenantId])
}

model SaleItem {
  id         String   @id @default(uuid())
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float
  totalPrice Float
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ReturnTransaction {
  id           String       @id @default(uuid())
  saleId       String
  sale         Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  reason       String
  refundAmount Float
  tenantId     String
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items        ReturnItem[]
  createdAt    DateTime     @default(now())
}

model ReturnItem {
  id        String            @id @default(uuid())
  returnId  String
  returnTx  ReturnTransaction @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int
  unitPrice Float
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  poNumber    String
  supplierId  String
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  status      String
  totalAmount Float
  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items       PurchaseOrderItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([poNumber, tenantId])
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  quantity        Int
  unitCost        Float
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Employee {
  id          String       @id @default(uuid())
  userId      String?      @unique
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  email       String
  phone       String?
  department  String?
  designation String?
  salary      Float        @default(0)
  joiningDate DateTime     @default(now())
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attendance  Attendance[]
  leaves      LeaveRequest[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attendance {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime
  status     String
  checkIn    DateTime?
  checkOut   DateTime?
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id         String    @id @default(uuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  type       String
  reason     String?
  status     String
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  module    String
  details   String?
  ipAddress String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model StockAdjustment {
  id          String    @id @default(uuid())
  productId   String
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity    Int
  type        String
  reason      String?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model StockTransfer {
  id              String    @id @default(uuid())
  productId       String
  fromWarehouseId String
  fromWarehouse   Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  toWarehouseId   String
  toWarehouse     Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Cascade)
  quantity        Int
  status          String
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
